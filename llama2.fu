public abstract class Loader
{
	public abstract void Open!(string path);
	public abstract int ReadInt!();
	public abstract float ReadFloat!();
	public abstract void ReadWeights!(short[]! a, nint n);
	public abstract void SkipBytes!(nint n);
	internal short[]# AllocateAndReadWeights!(nint n)
	{
		short[]# a = new short[n];
		ReadWeights(a, n);
		return a;
	}
	public abstract string() ReadString!();
	public abstract void Close!();
}

class Transformer
{
	int Dim;
	int HiddenDim;
	int Layers;
	int Heads;
	int KVHeads;
	int VocabSize;
	int SeqLen;
	short[]# TokenEmbeddingTable;
	short[]# RmsAttWeight;
	short[]# RmsFfnWeight;
	short[]# WQ;
	short[]# WK;
	short[]# WV;
	short[]# WO;
	short[]# W1;
	short[]# W2;
	short[]# W3;
	short[]# RmsFinalWeight;
	short[]# WCls;

	float[]# X;
	float[]# XB;
	float[]# XB2;
	float[]# HB;
	float[]# HB2;
	float[]# Q;
	float[]# Att;
	float[]# Logits;
	float[]# KeyCache;
	float[]# ValueCache;

	public void Load!(Loader! loader)
	{
		Dim = loader.ReadInt();
		HiddenDim = loader.ReadInt();
		Layers = loader.ReadInt();
		Heads = loader.ReadInt();
		KVHeads = loader.ReadInt();
		int i = loader.ReadInt();
		bool sharedWeights = i > 0;
		VocabSize = Math.Abs(i);
		SeqLen = loader.ReadInt();
		TokenEmbeddingTable = loader.AllocateAndReadWeights(VocabSize * Dim);
		nint n = Dim * Layers;
		RmsAttWeight = loader.AllocateAndReadWeights(n);
		int headSize = Dim / Heads;
		WQ = loader.AllocateAndReadWeights(Heads * headSize * n);
		WK = loader.AllocateAndReadWeights(KVHeads * headSize * n);
		WV = loader.AllocateAndReadWeights(KVHeads * headSize * n);
		WO = loader.AllocateAndReadWeights(Heads * headSize * n);
		RmsFfnWeight = loader.AllocateAndReadWeights(n);
		W1 = loader.AllocateAndReadWeights(HiddenDim * n);
		W2 = loader.AllocateAndReadWeights(HiddenDim * n);
		W3 = loader.AllocateAndReadWeights(HiddenDim * n);
		RmsFinalWeight = loader.AllocateAndReadWeights(Dim);
		if (sharedWeights)
			WCls = TokenEmbeddingTable;
		else
			WCls = loader.AllocateAndReadWeights(VocabSize * Dim);

		X = new float[Dim];
		XB = new float[Dim];
		XB2 = new float[Dim];
		HB = new float[HiddenDim];
		HB2 = new float[HiddenDim];
		Q = new float[Dim];
		Att = new float[Heads * SeqLen];
		Logits = new float[VocabSize];
		int cacheSize = Dim * KVHeads / Heads * Layers * SeqLen;
		KeyCache = new float[cacheSize];
		ValueCache = new float[cacheSize];
	}

	internal int GetVocabSize() => VocabSize;

	internal int GetSeqLen() => SeqLen;

	static float ExpandWeight(short i) => BitConverter.Int32BitsToSingle(i << 16);

	static void RmsNorm(float[]! o, float[] x, short[] weight, int weightOffset, int size)
	{
		float ss =0;
		for (int i = 0; i < size; i++)
			ss += x[i] * x[i];
		ss = 1 / Math.Sqrt(ss / size + 1e-5);
		for (int i = 0; i < size; i++)
			o[i] = ss * x[i] * ExpandWeight(weight[weightOffset + i]);
	}

	internal static void SoftMax(float[]! x, int xOffset, int size)
	{
		float max = x[0];
		for (int i = 1; i < size; i++) {
			if (max < x[xOffset + i])
				max = x[xOffset + i];
		}
		float sum = 0;
		for (int i = 0; i < size; i++)
			sum += x[xOffset + i] = Math.Exp(x[xOffset + i] - max);
		for (int i = 0; i < size; i++)
			x[xOffset + i] /= sum;
	}

	static void MatMul(float[]! o, int oOffset, float[] x, short[] w, int wOffset, int n, int d)
	{
		int i;
#if OPENMP
		native {
			#pragma omp parallel for private(i)
		}
#endif
		for (i = 0; i < d; i++) {
			float v = 0;
			for (int j = 0; j < n; j++)
				v += ExpandWeight(w[wOffset + i * n + j]) * x[j];
			o[oOffset + i] = v;
		}
	}

	public float[]! Forward!(int token, int pos)
	{
		int kvDim = Dim * KVHeads / Heads;
		int kvMul = Heads / KVHeads;
		int headSize = Dim / Heads;
		for (int i = 0; i < Dim; i++)
			X[i] = ExpandWeight(TokenEmbeddingTable[token * Dim + i]);
		for (int l = 0; l < Layers; l++) {
			RmsNorm(XB, X, RmsAttWeight, l * Dim, Dim);

			int loff = l * SeqLen * kvDim;
			int k = loff + pos * kvDim;
			MatMul(Q, 0, XB, WQ, l * Dim * Dim, Dim, Dim);
			MatMul(KeyCache, k, XB, WK, l * Dim * kvDim, Dim, kvDim);
			MatMul(ValueCache, k, XB, WV, l * Dim * kvDim, Dim, kvDim);

			for (int i = 0; i < Dim; i += 2) {
				float headDim = i % headSize;
				float freq = Math.Pow(10000, -headDim / headSize);
				float val = pos * freq;
				float fcr = Math.Cos(val);
				float fci = Math.Sin(val);
				float v0 = Q[i];
				float v1 = Q[i + 1];
				Q[i] = v0 * fcr - v1 * fci;
				Q[i + 1] = v0 * fci + v1 * fcr;
				if (i < kvDim) {
					v0 = KeyCache[k + i];
					v1 = KeyCache[k + i + 1];
					KeyCache[k + i] = v0 * fcr - v1 * fci;
					KeyCache[k + i + 1] = v0 * fci + v1 * fcr;
				}
			}

			for (int h = 0; h < Heads; h++) {
				int q = h * headSize;
				int att = h * SeqLen;
				for (int t = 0; t <= pos; t++) {
					k = loff + t * kvDim + h / kvMul * headSize;
					float score = 0;
					for (int i = 0; i < headSize; i++)
						score += Q[q + i] * KeyCache[k + i];
					Att[att + t] = score / Math.Sqrt(headSize);
				}

				SoftMax(Att, att, pos + 1);

				XB.Fill(0, q, headSize);
				for (int t = 0; t <= pos; t++) {
					int v = loff + t * kvDim + h / kvMul * headSize;
					float a = Att[att + t];
					for (int i = 0; i < headSize; i++)
						XB[q + i] += a * ValueCache[v + i];
				}
			}

			MatMul(XB2, 0, XB, WO, l * Dim * Dim, Dim, Dim);

			for (int i = 0; i < Dim; i++)
				X[i] += XB2[i];

			RmsNorm(XB, X, RmsFfnWeight, l * Dim, Dim);

			MatMul(HB, 0, XB, W1, l * Dim * HiddenDim, Dim, HiddenDim);
			MatMul(HB2, 0, XB, W3, l * Dim * HiddenDim, Dim, HiddenDim);

			for (int i = 0; i < HiddenDim; i++) {
				float val = HB[i];
				val *= 1 / (1 + Math.Exp(-val));
				HB[i] = val * HB2[i];
			}

			MatMul(XB, 0, HB, W2, l * Dim * HiddenDim, HiddenDim, Dim);

			for (int i = 0; i < Dim; i++)
				X[i] += XB[i];
		}
		RmsNorm(X, X, RmsFinalWeight, 0, Dim);
		MatMul(Logits, 0, X, WCls, 0, Dim, VocabSize);
		return Logits;
	}
}

class Tokenizer
{
	string()[]# Vocab;
	float[]# VocabScores;
	Dictionary<string, int>() VocabToToken;
	int VocabSize;
	List<int>() Prompt;
	int PromptIndex;

	public void Load!(Loader! loader, int vocabSize)
	{
		Vocab = new string()[vocabSize];
		VocabScores = new float[vocabSize];
		VocabToToken.Clear();
		VocabSize = vocabSize;
		loader.SkipBytes(4); // MaxTokenLength
		for (int i = 0; i < vocabSize; i++) {
			VocabScores[i] = loader.ReadFloat();
			Vocab[i] = loader.ReadString();
			string s = Vocab[i];
			if (s.Length == 6 && s.StartsWith("<0x") && s[5] == '>') {
				int c;
				if (c.TryParse(s.Substring(3, 2), 16)) {
					byte[1] b;
					b[0] = c;
					Vocab[i] = Encoding.UTF8.GetString(b, 0, 1);
				}
			}
		}
	}

	public string Decode(int token) => Vocab[token];

	public void SetPrompt!(string text)
	{
		if (VocabToToken.Count == 0) {
			for (int i = 0; i < VocabSize; i++)
				VocabToToken[Vocab[i]] = i;
		}
		PromptIndex = 0;
		Prompt.Clear();
		Prompt.Add(1); // bos
		if (text.Length > 0)
			Prompt.Add(VocabToToken[" "]);
		foreach (int c in text) {
			byte[1] b;
			b[0] = c;
			string() s = Encoding.UTF8.GetString(b, 0, 1);
			Prompt.Add(VocabToToken.ContainsKey(s) ? VocabToToken[s] : 3 + (c & 0xff));
		}
		for (;;) {
			float bestScore = Math.NegativeInfinity;
			int bestId = 0;
			int bestIdx = -1;
			for (int i = 0; i + 1 < Prompt.Count; i++) {
				string() s = Vocab[Prompt[i]] + Vocab[Prompt[i + 1]];
				if (VocabToToken.ContainsKey(s)) {
					int id = VocabToToken[s];
					if (bestScore < VocabScores[id]) {
						bestScore = VocabScores[id];
						bestId = id;
						bestIdx = i;
					}
				}
			}
			if (bestIdx < 0)
				break;
			Prompt.RemoveAt(bestIdx + 1);
			Prompt[bestIdx] = bestId;
		}
	}

	public bool HasPromptToken() => PromptIndex < Prompt.Count;

	public int GetPromptToken!() => Prompt[PromptIndex++];
}

class Sampler
{
	float Temperature = 1;
	long RandomState;

	public void SetTemperature!(float value)
	{
		Temperature = value;
	}

	public void SetRandomSeed!(long value)
	{
		RandomState = value;
	}

	static int ArgMax(float[]! probabilities, int n)
	{
		int maxI = 0;
		float maxP = probabilities[0];
		for (int i = 1; i < n; i++) {
			if (maxP < probabilities[i]) {
				maxP = probabilities[i];
				maxI = i;
			}
		}
		return maxI;
	}

	static long LowBits(int n)
	{
		long one = 1;
		return (one << n) - 1;
	}

	float NextRandom!()
	{
		// https://en.wikipedia.org/wiki/Xorshift#xorshift.2A
		long state = RandomState;
		state ^= state >> 12 & LowBits(52);
		state ^= (state & LowBits(39)) << 25;
		state ^= state >> 27 & LowBits(37);
		RandomState = state;
		float f = (state * 0x2545f4914f6cdd1d >> 40) & LowBits(24);
		return f / 16777216;
	}

	public int Sample!(float[]! logits, int n)
	{
		if (Temperature == 0)
			return ArgMax(logits, n);
		for (int i = 0; i < n; i++)
			logits[i] /= Temperature;
		Transformer.SoftMax(logits, 0, n);
		float coin = NextRandom();
		float cdf = 0;
		for (int i = 0; i < n; i++) {
			cdf += logits[i];
			if (coin < cdf)
				return i;
		}
		return n - 1; // in case of rounding errors
	}
}

public class Llama2
{
	Transformer() Trans;
	Tokenizer() Tok;
	Sampler() Samp;
	int Token;

	public Llama2()
	{
	}

	public void Load!(Loader! loader, string modelPath, string tokenizerPath)
	{
		loader.Open(modelPath);
		Trans.Load(loader);
		loader.Close();
		loader.Open(tokenizerPath);
		Tok.Load(loader, Trans.GetVocabSize());
		loader.Close();
	}

	public int GetSeqLen() => Trans.GetSeqLen();

	public void SetTemperature!(float value)
	{
		Samp.SetTemperature(value);
	}

	public void SetRandomSeed!(long value)
	{
		Samp.SetRandomSeed(value);
	}

	public void SetRawPrompt!(string prompt)
	{
		Tok.SetPrompt(prompt);
	}

	void FeedPrompt!()
	{
		if (Tok.HasPromptToken())
			Token = Tok.GetPromptToken();
	}

	public string? ForwardGenerate!(int pos)
	{
		FeedPrompt();
		if (pos != 0 && Token == 1)
			return null;
		string text = pos == 0 ? "" : Tok.Decode(Token);
		float[]! logits = Trans.Forward(Token, pos);
		if (!Tok.HasPromptToken())
			Token = Samp.Sample(logits, Trans.GetVocabSize());
		return text;
	}

	public void SetChatPrompt!(string prompt, string systemPrompt)
	{
		if (systemPrompt.Length > 0)
			SetRawPrompt($"[INST] <<SYS>>\n{systemPrompt}\n<</SYS>>\n\n{prompt} [/INST]");
		else
			SetRawPrompt($"[INST] {prompt} [/INST]");
	}

	public string? ForwardChat!(int pos)
	{
		FeedPrompt();
		float[]! logits = Trans.Forward(Token, pos);
		if (Tok.HasPromptToken())
			return "";
		if (Token == 2)
			return null;
		Token = Samp.Sample(logits, Trans.GetVocabSize());
		return Token == 2 ? "\n" : Tok.Decode(Token);
	}
}
