<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RollForward>LatestMajor</RollForward>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <Transpile Include="../*.fu" />
    <Compile Include="*.cs" />
  </ItemGroup>

  <Target Name="Transpile" BeforeTargets="BeforeCompile" Inputs="@(Transpile)" Outputs="obj\llama2cli.cs">
    <ItemGroup>
      <Compile Include="obj\llama2cli.cs" />
    </ItemGroup>
    <Exec Command="fut -o obj\llama2cli.cs @(Transpile, ' ')" />
  </Target>

</Project>
